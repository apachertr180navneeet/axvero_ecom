        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) {",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"czxj8inwx@mozmail.com\",\n    \"password\": \"Test@321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v2/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v2",
                "auth",
                "login"
              ]
            },
            "description": "FrontendAuthController. Email or phone in `email` field. On success, saves access_token to collection variable automatically."
          },
          "response": []
        },
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
